}, {
  "@id" : "http://si-digital-framework.org/SI/units/coulomb",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://si-digital-framework.org/SI#hasDefiningEquation" : [ {
    "@value" : "1\\;{\\rm{C}} = \\left(\\frac{{9\\:192\\:631\\:770} \\times {e}}{{1.602\\:176\\:634 \\times 10^{-19}} \\times \\Delta\\nu_{\\rm{Cs}}}\\right) {\\rm{s}}^{-1}"
  } ],
  "http://si-digital-framework.org/SI#hasDefiningResolution" : [ {
    "@id" : "http://si-digital-framework.org/bodies/CGPM#CGPM9-Res7"
  } ],
